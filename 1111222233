# Compare network on all 3 brokers
for b in 0 1 2; do
  echo "=== broker-$b ==="
  oc exec dev-kafka-cluster-broker-$b -n dev-kafka -- \
    cat /proc/net/dev | grep eth0
done


# Check broker-1 CPU via proc
oc exec dev-kafka-cluster-broker-1 -n dev-kafka -- \
  cat /proc/loadavg


# Check how many threads broker-1 is running
oc exec dev-kafka-cluster-broker-1 -n dev-kafka -- \
  ls /proc/$(cat /proc/1/status | grep PPid | awk '{print $2}')/task | wc -l 2>/dev/null || \
oc exec dev-kafka-cluster-broker-1 -n dev-kafka -- \
  cat /proc/1/status | grep -E "Threads|VmRSS|VmPeak"


# Check broker-1 open file descriptors - heavy I/O?
oc exec dev-kafka-cluster-broker-1 -n dev-kafka -- \
  ls /proc/1/fd | wc -l
