for p in 1 686 1491223; do
  echo "=== PID $p ==="
  oc exec dev-kafka-cluster-broker-1 -n dev-kafka -- cat /proc/$p/cmdline 2>/dev/null | tr '\0' ' '
  echo ""
done

# Real memory/thread count for the JVM
oc exec dev-kafka-cluster-broker-1 -n dev-kafka -- cat /proc/<pid>/status | grep -E "Threads|VmRSS|VmPeak"

# Live CPU consumption breakdown
oc exec dev-kafka-cluster-broker-1 -n dev-kafka -- cat /proc/<pid>/stat | awk '{print "utime:", $14, "stime:", $15}'
