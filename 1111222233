# Real CPU/mem per pod, live
oc adm top pods -n dev-kafka -l strimzi.io/pool-name=broker

# Find the real Kafka JVM pid inside the pod
oc exec dev-kafka-cluster-broker-1 -n dev-kafka -- ps aux | grep java

# Then loadavg comparison across all 3, for context
for b in 0 1 2; do
  echo "=== broker-$b ==="
  oc exec dev-kafka-cluster-broker-$b -n dev-kafka -- cat /proc/loadavg
done


