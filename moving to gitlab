kafkaConnect:
    enabled: true
    name: "dev-kafka-connect-mq"
    replicas: 3
    bootstrapServers: "dev-kafka-cluster-kafka-bootstrap.dev-kafka.svc.cluster.local:9093"
    image: "epaynonprod-registry-quay-quay-enterprise.apps.dev.epay.sbi/redhatdefultimage/debeziumconnect:01"
    imagePullSecrets:
      - microservices-dev-pull-secret
    resources:
      requests:
        memory: "4Gi"
        cpu: "2"
      limits:
        memory: "8Gi"
        cpu: "4"
    config:
      group:
        id: "dev-kafka-connect-mq-cluster"
      offset:
        storage:
          topic: "dev-kafka-connect-mq-offsets"
        flush:
          interval:
            ms: 10000
          timeout:
            ms: 5000
      config:
        storage:
          topic: "dev-kafka-connect-mq-configs"
      status:
        storage:
          topic: "dev-kafka-connect-mq-status"
      session:
        timeout:
          ms: 60000
      heartbeat:
        interval:
          ms: 20000
      rebalance:
        timeout:
          ms: 120000

    connectors:
      - name: "neft-mq-source"
        class: "com.ibm.eventstreams.connect.mqsource.MQSourceConnector"
        tasksMax: 1
        config:
          mq.queue.manager: "SBI_NEFT"
          mq.connection.name.list: "10.176.10.213(2001)"
          mq.channel.name: "SBIEPAY2.SVRCONN"
          mq.queue: "NeftInboundQueue"
