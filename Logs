oc get pods -n dev-kafka -o json | python3 << 'EOF'
import json, sys
data = json.load(sys.stdin)
print("{:<55} {:<12} {:<12} {:<12} {:<12}".format("Pod", "CPU-Req", "CPU-Lim", "Mem-Req", "Mem-Lim"))
print("-" * 103)
for pod in data['items']:
    name = pod['metadata']['name']
    for c in pod['spec']['containers']:
        res = c.get('resources', {})
        req = res.get('requests', {})
        lim = res.get('limits', {})
        print("{:<55} {:<12} {:<12} {:<12} {:<12}".format(
            name,
            req.get('cpu', 'none'),
            lim.get('cpu', 'none'),
            req.get('memory', 'none'),
            lim.get('memory', 'none')
        ))
EOF
