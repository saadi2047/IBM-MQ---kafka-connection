oc adm top pod -n dev-kafka

oc get pods -n dev-kafka -o json | python3 -c "
import json, sys
data = json.load(sys.stdin)
print(f'{'Pod':<55} {'CPU Req':<10} {'CPU Lim':<10} {'Mem Req':<10} {'Mem Lim':<10}')
print('-'*95)
for pod in data['items']:
    name = pod['metadata']['name']
    for c in pod['spec']['containers']:
        res = c.get('resources', {})
        req = res.get('requests', {})
        lim = res.get('limits', {})
        cpu_req = req.get('cpu', 'none')
        cpu_lim = lim.get('cpu', 'none')
        mem_req = req.get('memory', 'none')
        mem_lim = lim.get('memory', 'none')
        print(f'{name:<55} {cpu_req:<10} {cpu_lim:<10} {mem_req:<10} {mem_lim:<10}')
"
