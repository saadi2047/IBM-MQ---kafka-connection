oc get nodes -l env=dev
oc get nodes --show-labels | grep -v master | grep -v infra | head



template:
    pod:
      {{- if .Values.kafka.kafkaConnect.image }}
      image: {{ .Values.kafka.kafkaConnect.image }}
      {{- end }}
      {{- if .Values.kafka.kafkaConnect.imagePullSecrets }}
      imagePullSecrets:
        {{- range .Values.kafka.kafkaConnect.imagePullSecrets }}
        - name: {{ . }}
        {{- end }}
      {{- end }}
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
              - matchExpressions:
                  - key: env
                    operator: In
                    values: ["dev"]
