# templates/cd/deploy.single.yml
# CD orchestrator — single service deploy
# Used by deployment repo when SERVICE_NAME + ENV known at trigger time

workflow:
  rules:

    # #--------------------------------------------------------------------#
    # # Block branch creation pipelines
    # #--------------------------------------------------------------------#
    # - if: '$CI_COMMIT_BEFORE_SHA == "0000000000000000000000000000000000000000" && $CI_PIPELINE_SOURCE == "push"'
    #   when: never

    #--------------------------------------------------------------------#
    # ALWAYS allow downstream pipelines
    # (microservice repo → deployment repo)
    #--------------------------------------------------------------------#
    - if: '$CI_PIPELINE_SOURCE == "pipeline"'
      when: always

    #--------------------------------------------------------------------#
    # Avoid DUPLICATE pipelines: when a branch push has an open MR,
    # run only the merge_request pipeline and skip the branch (push) one.
    # (first-match-wins, so this must sit before the MR/branch allow rules)
    #--------------------------------------------------------------------#
    - if: '$CI_COMMIT_BRANCH && $CI_OPEN_MERGE_REQUESTS && $CI_PIPELINE_SOURCE == "push"'
      when: never
    #--------------------------------------------------------------------#

    
    #--------------------------------------------------------------------#
    # BLOCK MR pipelines targeting MAIN
    # Prevents deployment before approval
    #--------------------------------------------------------------------#
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event" && $CI_MERGE_REQUEST_TARGET_BRANCH_NAME == "main"'
      when: never


    #--------------------------------------------------------------------#
    # Allow MR pipelines for NON-main branches
    # (release → develop etc.)
    #--------------------------------------------------------------------#
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
      when: always


    #--------------------------------------------------------------------#
    # Deploy AFTER merge (push to main)
    #--------------------------------------------------------------------#
    - if: '$CI_COMMIT_BRANCH == "main" && $CI_PIPELINE_SOURCE == "push"'
      when: always


    #--------------------------------------------------------------------#
    # Allow release branches deployment
    #--------------------------------------------------------------------#
    # - if: '$CI_COMMIT_BRANCH =~ /^release\/.*$/ && $CI_PIPELINE_SOURCE == "push"'
    #   when: always


    #--------------------------------------------------------------------#
    # Allow develop branches deployment
    #--------------------------------------------------------------------#
    # - if: '$CI_COMMIT_BRANCH =~ /^develop\/.*$/ && $CI_PIPELINE_SOURCE == "push"'
    #   when: always


    #--------------------------------------------------------------------#
    # Block branch creation pipelines
    #--------------------------------------------------------------------#
    - if: '$CI_COMMIT_BEFORE_SHA == "0000000000000000000000000000000000000000" && $CI_PIPELINE_SOURCE == "push"'
      when: never


    #--------------------------------------------------------------------#
    # Skip CI bot commits
    #--------------------------------------------------------------------#
    - if: '$CI_COMMIT_AUTHOR == "ci" && $CI_COMMIT_AUTHOR_EMAIL == "ci.cedge@sbi.co.in"'
      when: never


    #--------------------------------------------------------------------#
    # Allow tags (production releases)
    #--------------------------------------------------------------------#
    - if: '$CI_COMMIT_TAG'
      when: always


    #--------------------------------------------------------------------#
    # Block everything else
    #--------------------------------------------------------------------#
    - when: never

stages:
  - publish     # update image tag in values.yaml
  - validate    # helm dry-run + service config check
  - deploy      # helm upgrade to OCP cluster
  # - verify      # rollout status + health check
  # - notify      # slack + jira

include:
  - local: 'cd/publish/values.update.yml'
  - local: 'cd/helm/helm.deploy.yml'
  # - local: 'cd/verify/verify.rollout.yml'
  # - local: 'cd/verify/verify.health.yml'
  # - local: 'cd/notify/notify.slack.yml'
  # - local: 'cd/notify/notify.jira.yml'

update-tag:
  extends:
    - .update_tag
  rules:
    - if: '$CI_PIPELINE_SOURCE == "pipeline"'
