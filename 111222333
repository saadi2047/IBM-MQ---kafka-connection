{{- if and .Values.kafka.enabled .Values.kafka.kafkaConnect.enabled }}
# Kafka Connect Cluster for Database/MQ Integration
apiVersion: kafka.strimzi.io/v1beta2
kind: KafkaConnect
metadata:
  name: {{ .Values.kafka.kafkaConnect.name }}
  namespace: {{ .Values.kafka.namespace }}
  labels:
    app.kubernetes.io/name: {{ .Values.kafka.kafkaConnect.name }}
    app.kubernetes.io/instance: {{ .Release.Name }}
    app.kubernetes.io/component: kafka-connect
    environment: {{ .Values.global.environment }}
  annotations:
    # Enable use of KafkaConnector resources
    strimzi.io/use-connector-resources: "true"
    argocd.argoproj.io/sync-wave: "9"
spec:
  version: {{ .Values.kafka.cluster.version }}
  replicas: {{ .Values.kafka.kafkaConnect.replicas }}
  bootstrapServers: {{ .Values.kafka.kafkaConnect.bootstrapServers }}
  {{- if .Values.kafka.kafkaConnect.image }}
  image: {{ .Values.kafka.kafkaConnect.image }}
  {{- end }}

  # Liveness probe - prevents kubelet from killing Connect pods
  # during broker rolling restarts or GC pauses (root cause of exit 137 restarts)
  livenessProbe:
    initialDelaySeconds: {{ .Values.kafka.kafkaConnect.livenessProbe.initialDelaySeconds | default 60 }}
    timeoutSeconds: {{ .Values.kafka.kafkaConnect.livenessProbe.timeoutSeconds | default 30 }}
    periodSeconds: {{ .Values.kafka.kafkaConnect.livenessProbe.periodSeconds | default 30 }}
    failureThreshold: {{ .Values.kafka.kafkaConnect.livenessProbe.failureThreshold | default 5 }}

  readinessProbe:
    initialDelaySeconds: {{ .Values.kafka.kafkaConnect.readinessProbe.initialDelaySeconds | default 60 }}
    timeoutSeconds: {{ .Values.kafka.kafkaConnect.readinessProbe.timeoutSeconds | default 30 }}
    periodSeconds: {{ .Values.kafka.kafkaConnect.readinessProbe.periodSeconds | default 30 }}
    failureThreshold: {{ .Values.kafka.kafkaConnect.readinessProbe.failureThreshold | default 5 }}

  # TLS configuration for secure connection (per AMQ examples)
  tls:
    trustedCertificates:
      - secretName: {{ .Values.kafka.cluster.name }}-cluster-ca-cert
        pattern: "*.crt"

  # Resource specifications
  resources:
    {{- if .Values.kafka.kafkaConnect.resources.requests }}
    requests:
      {{- if .Values.kafka.kafkaConnect.resources.requests.memory }}
      memory: {{ .Values.kafka.kafkaConnect.resources.requests.memory }}
      {{- end }}
      {{- if .Values.kafka.kafkaConnect.resources.requests.cpu }}
      cpu: {{ .Values.kafka.kafkaConnect.resources.requests.cpu }}
      {{- end }}
    {{- end }}
    {{- if .Values.kafka.kafkaConnect.resources.limits }}
    limits:
      {{- if .Values.kafka.kafkaConnect.resources.limits.memory }}
      memory: {{ .Values.kafka.kafkaConnect.resources.limits.memory }}
      {{- end }}
      {{- if .Values.kafka.kafkaConnect.resources.limits.cpu }}
      cpu: {{ .Values.kafka.kafkaConnect.resources.limits.cpu }}
      {{- end }}
    {{- end }}

  # Kafka Connect configuration (per AMQ examples)
  config:
    group.id: {{ .Values.kafka.kafkaConnect.config.group.id }}
    offset.storage.topic: {{ .Values.kafka.kafkaConnect.config.offset.storage.topic }}
    config.storage.topic: {{ .Values.kafka.kafkaConnect.config.config.storage.topic }}
    status.storage.topic: {{ .Values.kafka.kafkaConnect.config.status.storage.topic }}
    # Use default replication factor per AMQ examples
    config.storage.replication.factor: -1
    offset.storage.replication.factor: -1
    status.storage.replication.factor: -1
    # Plugin path + worker-default converters (match working cluster)
    plugin.path: /opt/kafka/plugins
    key.converter: org.apache.kafka.connect.storage.StringConverter
    value.converter: org.apache.kafka.connect.converters.ByteArrayConverter
    value.converter.schemas.enable: "false"
    {{- if .Values.kafka.kafkaConnect.config.offset.flush.interval.ms }}
    offset.flush.interval.ms: {{ .Values.kafka.kafkaConnect.config.offset.flush.interval.ms }}
    {{- end }}
    {{- if .Values.kafka.kafkaConnect.config.offset.flush.timeout.ms }}
    offset.flush.timeout.ms: {{ .Values.kafka.kafkaConnect.config.offset.flush.timeout.ms }}
    {{- end }}
    # Stability: prevent worker eviction on transient broker blips
    session.timeout.ms: {{ .Values.kafka.kafkaConnect.config.session.timeout.ms | default 60000 }}
    heartbeat.interval.ms: {{ .Values.kafka.kafkaConnect.config.heartbeat.interval.ms | default 20000 }}
    rebalance.timeout.ms: {{ .Values.kafka.kafkaConnect.config.rebalance.timeout.ms | default 120000 }}

  # Pod template with affinity and tolerations
  template:
    pod:
      {{- if .Values.kafka.kafkaConnect.imagePullSecrets }}
      imagePullSecrets:
        {{- range .Values.kafka.kafkaConnect.imagePullSecrets }}
        - name: {{ . }}
        {{- end }}
      {{- end }}

      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
            - matchExpressions:
              - key: node-role.kubernetes.io/worker
                operator: Exists
              - key: env
                operator: In
                values: ["dev"]

{{- if .Values.kafka.kafkaConnect.connectors }}
{{- range .Values.kafka.kafkaConnect.connectors }}
---
# Kafka Connector: {{ .name }}
apiVersion: kafka.strimzi.io/v1beta2
kind: KafkaConnector
metadata:
  name: {{ .name }}
  namespace: {{ $.Values.kafka.namespace }}
  labels:
    strimzi.io/cluster: {{ $.Values.kafka.kafkaConnect.name }}
    app.kubernetes.io/name: {{ .name }}
    app.kubernetes.io/instance: {{ $.Release.Name }}
    app.kubernetes.io/component: kafka-connector
    environment: {{ $.Values.global.environment }}
  annotations:
    argocd.argoproj.io/sync-wave: "10"
spec:
  class: {{ .class }}
  tasksMax: {{ .tasksMax | default 1 }}
  config:
    {{- range $key, $value := .config }}
    {{ $key }}: {{ $value | quote }}
    {{- end }}
{{- end }}
{{- end }}
{{- end }}
