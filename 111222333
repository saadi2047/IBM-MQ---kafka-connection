# Check broker-0 events
oc describe pod dev-kafka-cluster-broker-0 -n dev-kafka | grep -A5 "Events\|Reason\|Message" | tail -30

# Check if Strimzi operator triggered a rolling update
oc get events -n dev-kafka --sort-by='.lastTimestamp' | grep -iE "broker|roll|restart|update" | tail -20

# Check Strimzi cluster operator logs around midnight
oc logs -n openshift-operators $(oc get pods -n openshift-operators | grep strimzi | awk '{print $1}') --since=8h | grep -iE "roll|broker|reconcil|restart" | tail -30


# Check if there was a Kafka CR change that triggered reconciliation
oc get kafka dev-kafka-cluster -n dev-kafka -o yaml | grep -E "generation|resourceVersion|lastTransitionTime"
