# Check current node allocatable memory and usage
oc adm top node

# Check allocatable memory on each node
oc get nodes -o custom-columns=\
"NAME:.metadata.name,\
ALLOCATABLE-CPU:.status.allocatable.cpu,\
ALLOCATABLE-MEMORY:.status.allocatable.memory" | sort

# Check current operator memory usage
oc adm top pod -n openshift-operators

# Check what's currently consuming memory on the operator node
oc describe node worker1.dev.sbiepay.sbi | grep -A10 "Allocated resources"
oc describe node worker2.dev.sbiepay.sbi | grep -A10 "Allocated resources"
oc describe node worker3.dev.sbiepay.sbi | grep -A10 "Allocated resources"
