oc patch kafkaconnect dev-kafka-connect-mq -n dev-kafka --type=json -p '[
  {"op": "add", "path": "/spec/autoRestart", "value": {"enabled": true, "maxRestarts": 10}},
  {"op": "add", "path": "/spec/template/connectContainer/livenessProbe", "value": {"initialDelaySeconds": 60, "timeoutSeconds": 30, "periodSeconds": 30, "failureThreshold": 5}},
  {"op": "add", "path": "/spec/template/connectContainer/readinessProbe", "value": {"initialDelaySeconds": 60, "timeoutSeconds": 30, "periodSeconds": 30, "failureThreshold": 5}}
]'



oc get kafkaconnect dev-kafka-connect-mq -n dev-kafka -o yaml | grep -A10 "autoRestart\|livenessProbe"
