oc get kafkaconnect dev-kafka-connect-mq -n dev-kafka -o yaml | grep -A20 "livenessProbe\|readinessProbe"

# Check if connect-0 is near memory limit (limit is 8Gi)
oc top pod dev-kafka-connect-mq-connect-0 -n dev-kafka
oc top pod dev-kafka-connect-mq-connect-2 -n dev-kafka


# Also check if there's a heap dump or GC log being written
oc exec dev-kafka-connect-mq-connect-0 -n dev-kafka -- \
  jcmd 1 GC.heap_info 2>/dev/null || \
  oc exec dev-kafka-connect-mq-connect-0 -n dev-kafka -- \
  cat /proc/1/status | grep -E "VmRSS|VmPeak"
