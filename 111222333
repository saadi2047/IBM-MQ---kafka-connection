# Check if brokers restarted overnight
oc describe pod dev-kafka-cluster-broker-0 -n dev-kafka | grep -A5 "Last State\|Started\|Finished"

oc get pods -n dev-kafka | grep broker

# Check connector status
for c in neft-mq-source neft-mq-sink rtgs-mq-source rtgs-mq-sink; do
  echo "=== $c ==="
  oc exec dev-kafka-connect-mq-connect-1 -n dev-kafka -- \
    curl -s http://localhost:8083/connectors/$c/status | python3 -m json.tool
done

# Check connect pod restarts
oc get pods -n dev-kafka | grep connect-mq
