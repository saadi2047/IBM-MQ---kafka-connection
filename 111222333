oc get crd kafkaconnects.kafka.strimzi.io -o yaml | grep -E "^\s+livenessProbe:|^\s+readinessProbe:|^\s+autoRestart:" | head -10

# Check what's at spec level directly
oc get crd kafkaconnects.kafka.strimzi.io -o yaml | grep -A5 "spec:" | head -20

# Most importantly - find livenessProbe full path
oc get crd kafkaconnects.kafka.strimzi.io -o yaml | python3 -c "
import sys, yaml
data = yaml.safe_load(sys.stdin)
schema = data['spec']['versions'][0]['schema']['openAPIV3Schema']['properties']['spec']['properties']
print('Top level spec fields:', list(schema.keys()))
"
