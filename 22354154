# Check what registry SIT uses
helm get values epay-common -n sit-epay-common | grep -iE "imageRegistry|imagePull|registry" | head -10


# Check pull secrets in sit-kafka namespace
oc get secret -n sit-kafka | grep pull

# Check if the image is accessible from SIT
oc run test-pull --image=registry.dev.sbiepay.sbi:8443/library/kafka-connect-mq:v3 \
  --restart=Never -n sit-kafka --dry-run=client -o yaml | grep image

# Also check what imagePullSecrets the sit-kafka namespace has
oc get serviceaccount default -n sit-kafka -o yaml | grep -A5 "imagePullSecrets"

