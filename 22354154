# Check all 6 connectors are present and RUNNING
for c in neft-mq-source neft-mq-sink mis-mq-source mis-mq-sink rtgs-mq-source rtgs-mq-sink; do
  echo "=== $c ==="
  oc exec dev-kafka-connect-mq-connect-1 -n dev-kafka -- \
    curl -s http://localhost:8083/connectors/$c/status | python3 -m json.tool
done


# Confirm existing connectors/pods were NOT restarted
oc get pods -n dev-kafka | grep connect-mq


# Check the new MIS topics exist
oc exec dev-kafka-cluster-broker-0 -n dev-kafka -- \
  bin/kafka-topics.sh \
  --bootstrap-server localhost:9092 \
  --list | grep mis


