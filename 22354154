# Check all pods
oc get pods -n dev-kafka | grep -E "broker|connect-mq"

# Check connectors
for c in neft-mq-source neft-mq-sink rtgs-mq-source rtgs-mq-sink; do
  echo "=== $c ==="
  oc exec dev-kafka-connect-mq-connect-1 -n dev-kafka -- \
    curl -s http://localhost:8083/connectors/$c/status | python3 -m json.tool
done

# Check what triggered the broker restart today
oc get events -n dev-kafka --sort-by='.lastTimestamp' | tail -20

# Check operator memory - has it recovered properly after our change?
oc adm top pod -n openshift-operators

# Check if operator crashed again
oc get pods -n openshift-operators | grep amq-streams
oc describe pod -n openshift-operators $(oc get pods -n openshift-operators | grep amq-streams-cluster | awk '{print $1}') | grep -E "Restart|Last State|Exit Code"
